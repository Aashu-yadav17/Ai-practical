from collections import deque
import heapq

# Graph Representation
graph = {
    "L.U.J. & M.V.L.U. College": {
        "Dr. S. Radhakrishnan Road": 0.10,
        "Teli Gali": 0.15
    },
    "Dr. S. Radhakrishnan Road": {
        "L.U.J. & M.V.L.U. College": 0.10,
        "Old Nagardas Road": 0.15
    },
    "Teli Gali": {
        "L.U.J. & M.V.L.U. College": 0.15,
        "Nicolas Wadi Road": 0.20
    },
    "Old Nagardas Road": {
        "Dr. S. Radhakrishnan Road": 0.15,
        "Nicolas Wadi Road": 0.10,
        "Shiv Krupa Building": 0.15
    },
    "Nicolas Wadi Road": {
        "Teli Gali": 0.20,
        "Old Nagardas Road": 0.10,
        "Shiv Krupa Building": 0.10
    },
    "Shiv Krupa Building": {}
}


# Heuristic Values
heuristic = {
    "L.U.J. & M.V.L.U. College": 0.40,
    "Dr. S. Radhakrishnan Road": 0.30,
    "Teli Gali": 0.25,
    "Old Nagardas Road": 0.15,
    "Nicolas Wadi Road": 0.10,
    "Shiv Krupa Building": 0.00
}

# Start and Goal
start = "L.U.J. & M.V.L.U. College"
goal = "Shiv Krupa Building"


# Breadth First Search (BFS)
def bfs(graph, start, goal):
    queue = deque([(start, [start], 0)])
    visited = set()
    explored = 0

    while queue:
        node, path, cost = queue.popleft()

        if node in visited:
            continue

        visited.add(node)
        explored += 1

        if node == goal:
            return path, cost, explored

        for neighbor, weight in graph[node].items():
            if neighbor not in visited:
                queue.append((neighbor, path + [neighbor], cost + weight))

path, cost, explored = bfs(graph, start, goal)

print("===== BFS =====")
print("Path :", " -> ".join(path))
print("Total Cost :", cost, "km")
print("Nodes Explored :", explored)

# Depth First Search (DFS)
def dfs(graph, start, goal):
    stack = [(start, [start], 0)]
    visited = set()
    explored = 0

    while stack:
        node, path, cost = stack.pop()

        if node in visited:
            continue

        visited.add(node)
        explored += 1

        if node == goal:
            return path, cost, explored

        for neighbor, weight in reversed(list(graph[node].items())):
            if neighbor not in visited:
                stack.append((neighbor, path + [neighbor], cost + weight))

path, cost, explored = dfs(graph, start, goal)

print("\n===== DFS =====")
print("Path :", " -> ".join(path))
print("Total Cost :", cost, "km")
print("Nodes Explored :", explored)


# Uniform Cost Search (UCS)
def ucs(graph, start, goal):
    pq = [(0, start, [start])]
    visited = set()
    explored = 0

    while pq:
        cost, node, path = heapq.heappop(pq)

        if node in visited:
            continue

        visited.add(node)
        explored += 1

        if node == goal:
            return path, cost, explored

        for neighbor, weight in graph[node].items():
            if neighbor not in visited:
                heapq.heappush(
                    pq,
                    (cost + weight, neighbor, path + [neighbor])
                )

path, cost, explored = ucs(graph, start, goal)

print("\n===== UCS =====")
print("Path :", " -> ".join(path))
print("Total Cost :", cost, "km")
print("Nodes Explored :", explored)

# Greedy Best First Search

def greedy(graph, heuristic, start, goal):
    pq = [(heuristic[start], start, [start], 0)]
    visited = set()
    explored = 0

    while pq:
        h, node, path, cost = heapq.heappop(pq)

        if node in visited:
            continue

        visited.add(node)
        explored += 1

        if node == goal:
            return path, cost, explored

        for neighbor, weight in graph[node].items():
            if neighbor not in visited:
                heapq.heappush(
                    pq,
                    (
                        heuristic[neighbor],
                        neighbor,
                        path + [neighbor],
                        cost + weight
                    )
                )

path, cost, explored = greedy(graph, heuristic, start, goal)

print("\n===== Greedy Best First Search =====")
print("Path :", " -> ".join(path))
print("Total Cost :", cost, "km")
print("Nodes Explored :", explored)

# A* Search
def astar(graph, heuristic, start, goal):
    pq = [(heuristic[start], 0, start, [start])]
    visited = set()
    explored = 0

    while pq:
        f, g, node, path = heapq.heappop(pq)

        if node in visited:
            continue

        visited.add(node)
        explored += 1

        if node == goal:
            return path, g, explored

        for neighbor, weight in graph[node].items():
            if neighbor not in visited:
                new_cost = g + weight

                heapq.heappush(
                    pq,
                    (
                        new_cost + heuristic[neighbor],
                        new_cost,
                        neighbor,
                        path + [neighbor]
                    )
                )

path, cost, explored = astar(graph, heuristic, start, goal)
print("\n===== A* Search =====")
print("Path :", " -> ".join(path))
print("Total Cost :", cost, "km")
print("Nodes Explored :", explored)
print("Aashu Yadav")
